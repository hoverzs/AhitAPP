# Másold .env.local néven, és töltsd ki a saját értékeiddel.
ADMIN_PASSWORD="a-te-admin-jelszavad"
# Google AI Studio → API Keys (AIza... vagy új AQ. formátum)
GEMINI_API_KEY="a-google-ai-studio-api-kulcsod"
# Opcionális: GOOGLE_API_KEY (elsőbbség, ha mindkettő megvan)
# Dev: részletes Gemini hiba az admin UI-ban (alapértelmezett: be development módban)
# GEMINI_DEBUG_UI=true
# GEMINI_DEBUG_UI=false
# Helyi dev: NODE_ENV=development automatikusan engedékeny TLS-t használ (antivirus/proxy).
# Éles (Vercel): szigorú TLS — ne állíts NODE_TLS_REJECT_UNAUTHORIZED=0 élesben.
# Vercel Cron (vercel.json: 5 0 * * * → 00:05 UTC naponta) + külső retry ütemező
# Authorization: Bearer <CRON_SECRET> — NE kerüljön kliensoldalra (nincs NEXT_PUBLIC_ prefix)
# Külső cron (Hobby): POST /api/cron/process-generation-retries — 01:05, 02:05, 03:05 Bucharest
CRON_SECRET=hosszú-véletlen-string
# Publikus éles URL — Facebook megosztás, OG linkek (kötelező Vercel production-ben)
# Helyi dev: http://localhost:3000 | Éles: egyházmegyei domain vagy Vercel URL
# Példa: https://napi-ahitat.vercel.app  vagy  https://ahit.te-egyhazmegyed.hu
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Pexels stockfotó keresés (csak szerveroldalon) — https://www.pexels.com/api/
PEXELS_API_KEY=
# Opcionális: hány napnyi áhítat maradjon Redisben. 0 = nincs törlés (alapértelmezett).
# DEVOTIONAL_RETENTION_DAYS=0
